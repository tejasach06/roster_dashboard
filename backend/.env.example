# Required in production — generate with: openssl rand -hex 32
JWT_SECRET=replace-with-at-least-32-random-characters

# Allowed frontend origin(s), comma-separated if more than one, no trailing slash
CORS_ORIGIN=http://localhost:5173

# Optional production bootstrap when no admin account exists.
# Password must be at least 12 characters. Remove after first successful startup.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=replace-with-a-strong-one-time-password
# ADMIN_NAME=Admin

# Port the Express server listens on
PORT=3001
